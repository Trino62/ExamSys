# ExamSys — Variables de entorno
# Copia este archivo como .env y ajusta los valores.
# ⚠️  Nunca subas .env al repositorio.

# ── Base de datos ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
